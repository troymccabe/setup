#!/usr/bin/env sh
# ==============================================================================
# bootstrap — Remote entry point for troymccabe/setup
#
# Usage (normal):
#   curl -fsSL https://raw.githubusercontent.com/troymccabe/setup/main/mac/dev/bootstrap | sh
#
# Usage (dry run — previews what setup would do, no changes made):
#   curl -fsSL https://raw.githubusercontent.com/troymccabe/setup/main/mac/dev/bootstrap | sh -s -- --dry-run
#
# What this script does:
#   1. Downloads Brewfile, setup, and SHA256SUMS from the repo
#   2. Verifies file integrity via SHA-256 checksums
#   3. Hands off to setup (re-attaching the TTY so interactive prompts work)
# ==============================================================================

set -eu

REPO="troymccabe/setup"
BRANCH="main"
WORK_DIR="${HOME}/.setup-bootstrap"

# BASE_URL is resolved below to a specific commit SHA so all downloads come
# from a single, immutable snapshot. Fetching from `…/${BRANCH}/…` instead
# would hit raw.githubusercontent.com's CDN cache (~5 min per URL) and could
# return a mix of pre- and post-push file versions — typically observed as
# the SHA256SUMS check failing right after a push because the CI-updated
# SHA256SUMS hasn't aged out of cache yet.
BASE_URL=""

# ── Colours (tput — available on every macOS without bash) ───────────────────
_bold=$(tput bold   2>/dev/null || printf '')
_green=$(tput setaf 2 2>/dev/null || printf '')
_yellow=$(tput setaf 3 2>/dev/null || printf '')
_cyan=$(tput setaf  6 2>/dev/null || printf '')
_reset=$(tput sgr0  2>/dev/null || printf '')

info()    { printf '%s  ➜  %s%s\n' "${_cyan}"   "$*" "${_reset}"; }
success() { printf '%s  ✓  %s%s\n' "${_green}"  "$*" "${_reset}"; }
warn()    { printf '%s  ⚠  %s%s\n' "${_yellow}" "$*" "${_reset}"; }
header()  { printf '\n%s%s%s\n'    "${_bold}"    "$*" "${_reset}"; }
die()     { printf '%s  ✖  %s%s\n' "${_yellow}"  "$*" "${_reset}" >&2; exit 1; }

# ── Preflight ─────────────────────────────────────────────────────────────────
header "🚀  Bootstrap — ${REPO}"

command -v curl >/dev/null 2>&1 || die "curl is required but not installed."
command -v shasum >/dev/null 2>&1 || die "shasum is required but not installed."

# Work directory persists between runs — lets you re-run setup directly
# after a partial failure without re-downloading everything.
mkdir -p "${WORK_DIR}"
cd "${WORK_DIR}"

# ── Resolve branch to immutable commit SHA ───────────────────────────────────
# The GitHub commits API is served from api.github.com (much shorter cache
# than raw.githubusercontent.com), so it surfaces the true HEAD quickly after
# a push. Once resolved, every file download below uses a URL like
#   raw.githubusercontent.com/.../<sha>/mac/dev/<file>
# which is a unique cache key per commit — fresh on first fetch, immune to
# the stale `main/...` cache that's been observed serving mismatched files.
#
# `posix-shell-safe JSON extraction`: the API response includes the head
# commit SHA in `"sha":"<40-hex>"`. grep + cut is enough to pull it out
# without requiring jq (which isn't on a fresh Mac).
header "Resolving ${BRANCH} → commit SHA…"
COMMIT_SHA="$(curl -fsSL -H 'Cache-Control: no-cache' \
  "https://api.github.com/repos/${REPO}/branches/${BRANCH}" \
  | grep -m1 -oE '"sha"[[:space:]]*:[[:space:]]*"[0-9a-f]{40}"' \
  | cut -d'"' -f4)"
[ -n "${COMMIT_SHA}" ] || die "Could not resolve ${BRANCH} → commit SHA"
success "Pinned to ${COMMIT_SHA}"
BASE_URL="https://raw.githubusercontent.com/${REPO}/${COMMIT_SHA}/mac/dev"

# ── Download ──────────────────────────────────────────────────────────────────
header "Downloading files…"

for file in Brewfile setup SHA256SUMS avatar.png wallpaper.png; do
  info "Fetching ${file}…"
  # -f  fail loudly on HTTP errors (no silent 404 → garbage pipe)
  # -s  suppress progress meter
  # -S  show errors even with -s
  # -L  follow redirects
  curl -fsSL "${BASE_URL}/${file}" -o "${file}"
  success "${file}"
done

# ── Verify checksums ──────────────────────────────────────────────────────────
header "Verifying checksums…"

# shasum --check honours lines in SHA256SUMS; --ignore-missing skips entries
# not present locally (future-proofs against new files being added to the repo).
if ! shasum -a 256 --check SHA256SUMS --ignore-missing; then
  die "Checksum verification failed — the downloaded files may be corrupt or tampered with. Aborting."
fi
success "All checksums verified"

# ── Hand off to setup ──────────────────────────────────────────────────────
chmod +x "${WORK_DIR}/setup"

header "Launching setup…"
info "Working directory: ${WORK_DIR}"
info "(Re-run at any time with: bash ${WORK_DIR}/setup)"
echo ""

# Re-attach /dev/tty so that interactive prompts inside setup (sudo,
# gh auth login, App Store sign-in) receive keyboard input even though
# this script was piped from curl.
#
# Pass through any arguments (e.g. --dry-run) to setup.
# Prefer Homebrew bash 5 (if already installed) over the system bash 3.2.
# On a completely fresh machine this will fall back to /bin/bash, which is
# fine — the case statement in setup is written for bash 3.2 compatibility.
BASH_BIN="$(command -v bash)"
for candidate in /opt/homebrew/bin/bash /usr/local/bin/bash; do
  [ -x "$candidate" ] && BASH_BIN="$candidate" && break
done
exec "$BASH_BIN" "${WORK_DIR}/setup" "$@" </dev/tty
